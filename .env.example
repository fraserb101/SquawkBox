# Supabase (hosted Postgres + REST API)
SUPABASE_URL=
SUPABASE_KEY=
# Direct Postgres connection string, used by Alembic migrations only.
# Get from Supabase > Project Settings > Database > Connection string > URI.
DATABASE_URL=

# Redis (docker-compose service name is "redis")
REDIS_URL=redis://redis:6379/0

# News and AI
NEWSDATA_API_KEY=
TAVILY_API_KEY=
TOGETHER_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The sandbox number Twilio gives you, e.g. +14155238886 (include the +)
TWILIO_WHATSAPP_FROM=

# Public tunnel URL where Twilio reaches the webhook and fetches voice notes.
# For local dev this is your ngrok URL, e.g. https://abc123.ngrok-free.app
PUBLIC_BASE_URL=

# Stripe (can be left as test-mode values during local development)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENT_LINK=

# Admin and monitoring
ADMIN_SECRET=
SENTRY_DSN=

# Your sandbox number without the + (used to build wa.me referral deep links)
YOUR_WHATSAPP_NUMBER=
TERMS_URL=
